#
# General functions that should be fairly portable.
#
# In most cases, I prefer ~/sw/sh/<script> unless there's a reason to mutate
# the current shell's environment, or the command should only be enabled on
# specific systems.
#

# System specific.
[ -f "${HOME}/sw/etc/funcs.d/`uname -s`.sh" ] && . "${HOME}/sw/etc/funcs.d/`uname -s`.sh"
