[user]
	name = Terry M. Poulin
	# From Git 2.8 (2016) this effectively halts commit if user.email is
	# not set.
	useConfigOnly = true
[alias]
	st = !git status -s | grep -v '??'
	pp = log --graph --abbrev-commit --decorate --full-history --all
	# n.b. older versions of git lack the --cherry-mark flag.
	#      (1.7.0.x lacks it; 1.7.10.x has it.)
	history = log --graph --abbrev-commit --decorate --cherry-mark --full-history --all
	oneline = log --oneline
	graph = log --oneline --graph --decorate --cherry-mark
[color]
	ui = auto
[core]
	autocrlf = input

# Include additional configuration files.
#
# N.B. this requires >= Git 2.13 (2018) but great way to store e-mail address.
#
# Default identity for this system.
[include]
	path = .gitconfig.identity
# If the URL is write access to my GitHub, load my identity from this file. Needed on machines where user.email differs from other repos.
[includeIf "hasconfig:remote.*.url:git@github.com:Spidey01/**"]
	path = .gitconfig.github
# For projects in my workspace.
[includeIf "gitdir:~/sw/workspace/"]
	path = .gitconfig.workspace
# Create ~/.gitconfig.local to hold any system local overrides.
[include]
	path = .gitconfig.local
